{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": "dist/server.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "build:bin": "node src/bin/compile-binary.js",
    "lint": "tsc --noEmit"
  },
  "pkg": {
    "assets": [
      "dist/**/*",
      "src/**/*"
    ],
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-win-x64",
      "node20-macos-x64",
      "node20-macos-arm64"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/events": "^7.4.3",
    "@pixi/math": "^7.4.3",
    "@pixi/settings": "^7.4.3",
    "@pixi/ticker": "^7.4.3",
    "@pixi/utils": "^7.4.3",
    "@pixiv/three-vrm": "^3.5.3",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.9.0",
    "d3": "^7.9.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "front-matter": "^4.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pixi-live2d-display": "^0.5.0-beta",
    "pixi.js": "^7.4.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "smol-toml": "^1.6.1",
    "telegraf": "^4.16.3",
    "three": "^0.184.0",
    "vite": "^6.2.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.4.21",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
